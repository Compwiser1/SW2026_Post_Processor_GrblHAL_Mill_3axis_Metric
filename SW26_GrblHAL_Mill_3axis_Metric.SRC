:T:; ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~<EOL>
:T:;    Tool Change<EOL>
:T:;        Tool #<TOOL_NUM_RAW_DISP>: TAP ENDMILL <TOOL_COMMENT_DISP><EOL>
:T:; ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~<EOL>
*
:SECTION=TOOL_CHANGE_HDR_TYPE_222
:T:; ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~<EOL>
:T:;    Tool Change<EOL>
:T:;        Tool #<TOOL_NUM_RAW_DISP>: TAP BALLNOSE <TOOL_COMMENT_DISP><EOL>
:T:; ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~<EOL>
*
:SECTION=TOOL_CHANGE_HDR_TYPE_223
:T:; ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~<EOL>
:T:;    Tool Change<EOL>
:T:;        Tool #<TOOL_NUM_RAW_DISP>: TAP HOGNOSE <TOOL_COMMENT_DISP><EOL>
:T:; ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~<EOL>
*
:SECTION=TOOL_CHANGE_HDR_TYPE_204
:T:; ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~<EOL>
:T:;    Tool Change<EOL>
:T:;        Tool #<TOOL_NUM_RAW_DISP>: DRILL <TOOL_COMMENT_DISP><EOL>
:T:; ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~<EOL>
*
:SECTION=TOOL_CHANGE_HDR_TYPE_205
:T:; ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~<EOL>
:T:;    Tool Change<EOL>
:T:;        Tool #<TOOL_NUM_RAW_DISP>: BORE <TOOL_COMMENT_DISP><EOL>
:T:; ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~<EOL>
*
:SECTION=TOOL_CHANGE_HDR_TYPE_206
:T:; ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~<EOL>
:T:;    Tool Change<EOL>
:T:;        Tool #<TOOL_NUM_RAW_DISP>: REAM <TOOL_COMMENT_DISP><EOL>
:T:; ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~<EOL>
*
:SECTION=TOOL_CHANGE_HDR_TYPE_207
:T:; ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~<EOL>
:T:;    Tool Change<EOL>
:T:;        Tool #<TOOL_NUM_RAW_DISP>: TAP <TOOL_COMMENT_DISP><EOL>
:T:; ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~<EOL>
*
:SECTION=TOOL_CHANGE_HDR_TYPE_208
:T:; ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~<EOL>
:T:;    Tool Change<EOL>
:T:;        Tool #<TOOL_NUM_RAW_DISP>: CENTER DRILL <TOOL_COMMENT_DISP><EOL>
:T:; ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~<EOL>
*
:SECTION=TOOL_CHANGE_HDR_TYPE_209
:T:; ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~<EOL>
:T:;    Tool Change<EOL>
:T:;        Tool #<TOOL_NUM_RAW_DISP>: CORNER ROUND <TOOL_COMMENT_DISP><EOL>
:T:; ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~<EOL>
*
:SECTION=TOOL_CHANGE_HDR_TYPE_210
:T:; ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~<EOL>
:T:;    Tool Change<EOL>
:T:;        Tool #<TOOL_NUM_RAW_DISP>: COUNTERSINK <TOOL_COMMENT_DISP><EOL>
:T:; ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~<EOL>
